{
  "extends": "@repo/typescript-config/nextjs.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./app/*"],
      "@/public/*": ["../public/*"],
      "@/components/*": ["../components/*"],
      "@/stores/*": ["../stores/*"],
      "@/types/*": ["../types/*"],
      "components/*": ["./components/*"],
      "consts/*": ["./consts/*"],
      "hooks/*": ["./hooks/*"],
      "libs/*": ["./libs/*"],
      "providers/*": ["./providers/*"],
      "public/*": ["./public/*"],
      "stores/*": ["./stores/*"],
      "utils/*": ["./utils/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "next-env.d.ts",
    "next.config.js",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
