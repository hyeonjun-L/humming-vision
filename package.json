{
  "name": "humming-vision",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "turbo": "^2.9.17",
    "typescript": "5.8.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "fast-xml-parser": "^5.8.0",
    "handlebars": "^4.7.9",
    "liquidjs": "^10.27.0",
    "postcss": "^8.5.15",
    "path-to-regexp": "^8.4.2",
    "multer": "^2.1.1",
    "serialize-javascript": "^7.0.5",
    "tar": "^7.5.16",
    "svgo": "^3.3.3",
    "lodash": "^4.18.1",
    "preview-email": {
      "uuid": "^11.1.0"
    }
  },
  "dependencies": {
    "@nestjs/cli": "^11.0.7",
    "@nestjs/mapped-types": "*",
    "dotenv": "^17.2.1",
    "g": "^2.0.1"
  }
}
